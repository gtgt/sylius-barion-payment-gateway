{% extends '@SyliusAdmin/shared/layout/base.html.twig' %}

{% block title %}{{ 'sylius_barion.ui.wallet_history'|trans }} | {{ parent() }}{% endblock %}

{% block body %}
    <div class="page-wrapper">
        <div class="page-header d-print-none">
            <div class="container-xl">
                {% include '@SyliusBarionPaymentGatewayPlugin/admin/transaction/wallet/index/content/header/breadcrumbs.html.twig' %}
                <div class="row g-2 align-items-center">
                    <div class="col">
                        <h2 class="page-title">{{ 'sylius_barion.ui.wallet_history'|trans }}</h2>
                    </div>
                </div>
            </div>
        </div>

        <div class="page-body">
            <div class="container-xl">
                {% include '@SyliusBarionPaymentGatewayPlugin/admin/transaction/_tabs.html.twig' with { active_tab: 'wallet' } %}

                <div class="card mb-3">
                    <div class="card-body">
                        <form method="get" class="row g-3 align-items-end">
                            <div class="col-md-4">
                                <label class="form-label" for="paymentMethodId">{{ 'sylius.ui.payment_method'|trans }}</label>
                                <select id="paymentMethodId" name="paymentMethodId" class="form-select">
                                    {% for paymentMethod in paymentMethods %}
                                        <option
                                            value="{{ paymentMethod.id }}"
                                            {% if selectedPaymentMethod and selectedPaymentMethod.id == paymentMethod.id %}selected{% endif %}
                                        >
                                            {{ paymentMethod.name }}
                                        </option>
                                    {% endfor %}
                                </select>
                            </div>
                            <div class="col-md-2">
                                <label class="form-label" for="currency">{{ 'sylius.ui.currency'|trans }}</label>
                                <input id="currency" name="currency" class="form-control" value="{{ currency|default('') }}" placeholder="HUF">
                            </div>
                            <div class="col-md-2">
                                <label class="form-label" for="limit">{{ 'sylius_barion.ui.limit'|trans }}</label>
                                <input id="limit" name="limit" type="number" min="1" max="100" class="form-control" value="{{ limit }}">
                            </div>
                            <div class="col-md-2">
                                <button type="submit" class="btn btn-primary w-100">{{ 'sylius.ui.search'|trans }}</button>
                            </div>
                        </form>
                    </div>
                </div>

                {% if apiError %}
                    <div class="alert alert-warning">{{ apiError }}</div>
                {% endif %}

                {% if paymentMethods is empty %}
                    <div class="alert alert-info">{{ 'sylius_barion.ui.no_barion_payment_methods'|trans }}</div>
                {% elseif historyResponse %}
                    <div class="card">
                        <div class="table-responsive">
                            <table class="table card-table table-vcenter">
                                <thead>
                                    <tr>
                                        <th>{{ 'sylius.ui.date'|trans }}</th>
                                        <th>{{ 'sylius.ui.type'|trans }}</th>
                                        <th>{{ 'sylius.ui.description'|trans }}</th>
                                        <th class="text-end">{{ 'sylius.ui.amount'|trans }}</th>
                                        <th>{{ 'sylius.ui.currency'|trans }}</th>
                                        <th>{{ 'sylius.ui.status'|trans }}</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for item in historyResponse.items %}
                                        <tr>
                                            <td>{{ item.happenedAtUtc|default('-') }}</td>
                                            <td>{{ item.type }}</td>
                                            <td>{{ item.description|default('-') }}</td>
                                            <td class="text-end">{{ item.amount }}</td>
                                            <td>{{ item.currency }}</td>
                                            <td>
                                                {% if item.isInProgress %}
                                                    <span class="badge bg-yellow-lt">{{ 'sylius_barion.ui.in_progress'|trans }}</span>
                                                {% else %}
                                                    <span class="badge bg-green-lt">{{ 'sylius.ui.completed'|trans }}</span>
                                                {% endif %}
                                            </td>
                                            <td class="text-end">
                                                <a
                                                    class="btn btn-sm"
                                                    href="{{ path('sylius_barion_admin_transaction_wallet_show', {
                                                        historyItemId: item.id,
                                                        paymentMethodId: selectedPaymentMethod.id,
                                                    }) }}"
                                                >
                                                    {{ 'sylius.ui.show'|trans }}
                                                </a>
                                            </td>
                                        </tr>
                                    {% else %}
                                        <tr>
                                            <td colspan="7" class="text-center text-muted">{{ 'sylius.ui.no_results'|trans }}</td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>

                    {% if historyResponse.items is not empty %}
                        {% set lastItem = historyResponse.items|last %}
                        <div class="mt-3">
                            <a
                                class="btn"
                                href="{{ path('sylius_barion_admin_transaction_wallet_index', {
                                    paymentMethodId: selectedPaymentMethod.id,
                                    currency: currency,
                                    limit: limit,
                                    lastVisibleItemId: lastItem.id,
                                }) }}"
                            >
                                {{ 'sylius_barion.ui.load_more'|trans }}
                            </a>
                        </div>
                    {% endif %}
                {% endif %}
            </div>
        </div>
    </div>
{% endblock %}
